# Flow (1): LiveAvatar hosts the LiveKit room. Required.
LIVEAVATAR_API_KEY=
AVATAR_ID=
# Optional: defaults to https://api.liveavatar.com
LIVEAVATAR_BASE_URL=

# Flow (2): we own the LiveKit room. Required when running agent_dispatcher
# under AgentServer dispatch.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
