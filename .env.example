# --- LiveAvatar (required) ---
LIVEAVATAR_API_KEY=
AVATAR_ID=
# Optional: defaults to https://api.liveavatar.com
LIVEAVATAR_BASE_URL=

# --- LiveKit Cloud (required) ---
# Used by the agent's inference plugins (STT/LLM/TTS) to authenticate with
# the LiveKit inference gateway. The room itself is hosted by LiveAvatar in
# Flow 1; these creds belong to *your* LK Cloud project.
# In Flow 2, set LIVEKIT_URL to your project as well.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: DEBUG to see plugin-level logs. Defaults to INFO.
LOG_LEVEL=
